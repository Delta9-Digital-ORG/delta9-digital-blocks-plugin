{
	"name": "eightshift/delta9-digital-blocks-plugin",
	"description": "This repository contains all the tools you need to start building a modern WordPress project.",
	"private": true,
	"keywords": [
		"plugin",
		"eightshift",
		"Gutenberg",
		"WordPress"
	],
	"homepage": "https://eightshift.com/",
	"license": "MIT",
	"authors": [
		{
			"name": "Eightshift team",
			"email": "team@eightshift.com",
			"homepage": "https://eightshift.com/",
			"role": "Developer / IT Manager"
		}
	],
	"support": {
		"issues": "https://github.com/infinum/delta9-digital-blocks-plugin/issues",
		"source": "https://github.com/infinum/delta9-digital-blocks-plugin"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"infinum/eightshift-coding-standards": "^3.0",
		"php-stubs/wordpress-stubs": "^6.5",
		"szepeviktor/phpstan-wordpress": "^1.3",
		"wp-cli/wp-cli": "^2.9"
	},
	"require": {
		"php": ">=8.2",
		"infinum/eightshift-libs": "^8.0",
		"typisttech/imposter-plugin": "^0.6.2"
	},
	"autoload": {
		"psr-4": {
			"Delta9DigitalBlocksPlugin\\": "src/"
		}
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"sort-packages": true,
		"optimize-autoloader": true,
		"process-timeout": 2000,
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"typisttech/imposter-plugin": true
		}
	},
	"scripts": {
		"analyze": "@php ./vendor/bin/phpstan analyze",
		"standards:check": "@php ./vendor/squizlabs/php_codesniffer/bin/phpcs",
		"standards:fix": "@php ./vendor/squizlabs/php_codesniffer/bin/phpcbf"
	},
	"extra": {
		"imposter": {
			"namespace": "Delta9DigitalBlocksPluginVendor"
		}
	}
}
