{
	"$schema": "https://raw.githubusercontent.com/infinum/eightshift-frontend-libs/develop/schemas/block.json",
	"componentName": "age-verification-button",
	"title": "Age Verification Button",
	"componentClass": "age-verification-button",
	"componentJsClass": "js-age-verification-button",
	"attributes": {
		"ageVerificationButtonQuery": {
			"type": "string"
		},
		"ageVerificationButtonType": {
			"type": "string"
		},
		"ageVerificationButtonId": {
			"type": "string"
		},
		"ageVerificationButtonInitialItems": {
			"type": "string"
		},
		"ageVerificationButtonPerPageOverride": {
			"type": "integer"
		},
		"ageVerificationButtonUse": {
			"type": "boolean",
			"default": true
		},
		"ageVerificationButtonButtonContent": {
			"type": "string",
			"default": "open modal"
		}
	},
	"components": {
		"button": "button"
	}
}