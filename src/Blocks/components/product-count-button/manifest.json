{
	"$schema": "https://raw.githubusercontent.com/infinum/eightshift-frontend-libs/develop/schemas/component.json",
	"componentName": "product-count-button",
	"title": "Product Count Button",
	"componentClass": "btn",
	"example": {
		"attributes": {
			"productCountButtonContent": "This is a button",
			"productCountButtonUrl": "https://eightshift.com/",
			"productCountButtonId": "custom ID"
		}
	},
	"attributes": {
		"productCountButtonContent": {
			"type": "string"
		},
		"productCountButtonUrl": {
			"type": "string"
		},
		"productCountButtonId": {
			"type": "string"
		},
		"productCountButtonColor": {
			"type": "string",
			"default": "primary500"
		},
		"productCountButtonVariant": {
			"type": "string",
			"default": "fill"
		},
		"productCountButtonIsAnchor": {
			"type": "boolean",
			"default": false
		},
		"productCountButtonIsNewTab": {
			"type": "boolean",
			"default": false
		},
		"productCountButtonAttrs": {
			"type": "array"
		},
		"productCountButtonAriaLabel": {
			"type": "string"
		},
		"productCountButtonUse": {
			"type": "boolean",
			"default": true
		},
		"productCountButtonIconUse": {
			"type": "boolean",
			"default": false
		}
	},
	"components": {
		"icon": "icon"
	},
	"options": {
		"productCountButtonVariant": [
			{
				"label": "Filled",
				"value": "fill",
				"icon": "buttonFilled"
			},
			{
				"label": "Outlined",
				"value": "outline",
				"icon": "buttonOutline"
			},
			{
				"label": "Ghost",
				"value": "ghost",
				"icon": "buttonGhost"
			}
		],
		"productCountButtonColor": [
			"primary500",
			"black",
			"white"
		]
	},
	"variables": {
		"buttonColor": {
			"black": [
				{
					"variable": {
						"product-count-button-fill-background-color": "var(--global-colors-black)",
						"product-count-button-fill-background-color-hover": "var(--global-colors-primary700)",
						"product-count-button-fill-color": "var(--global-colors-white)",
						"product-count-button-fill-border-color": "var(--global-colors-black)",
						"product-count-button-fill-border-color-hover": "var(--global-colors-primary700)",
						"product-count-button-fill-border-color-focus": "transparent",
						"product-count-button-outline-color": "var(--global-colors-black)",
						"product-count-button-outline-color-hover": "var(--global-colors-primary700)",
						"product-count-button-outline-border-color": "var(--global-colors-black)",
						"product-count-button-outline-border-color-hover": "var(--global-colors-primary700)",
						"product-count-button-outline-border-color-focus": "transparent",
						"product-count-button-ghost-color": "var(--global-colors-black)",
						"product-count-button-ghost-color-hover": "var(--global-colors-primary700)"
					}
				}
			],
			"white": [
				{
					"variable": {
						"product-count-button-fill-background-color": "var(--global-colors-white)",
						"product-count-button-fill-background-color-hover": "var(--global-colors-gray100)",
						"product-count-button-fill-color": "var(--global-colors-black)",
						"product-count-button-fill-border-color": "var(--global-colors-white)",
						"product-count-button-fill-border-color-hover": "var(--global-colors-gray100)",
						"product-count-button-fill-border-color-focus": "transparent",
						"product-count-button-outline-color": "var(--global-colors-white)",
						"product-count-button-outline-color-hover": "var(--global-colors-gray100)",
						"product-count-button-outline-border-color": "var(--global-colors-white)",
						"product-count-button-outline-border-color-hover": "var(--global-colors-gray100)",
						"product-count-button-outline-border-color-focus": "transparent",
						"product-count-button-ghost-color": "var(--global-colors-white)",
						"product-count-button-ghost-color-hover": "var(--global-colors-gray100)"
					}
				}
			]
		},
		"buttonVariant": {
			"fill": [
				{
					"variable": {
						"product-count-button-background-color": "var(--button-fill-background-color, var(--global-colors-primary500))",
						"product-count-button-background-color-hover": "var(--button-fill-background-color-hover, var(--global-colors-primary700))",
						"product-count-button-color": "var(--button-fill-color, var(--global-colors-white))",
						"product-count-button-border": "1px solid var(--button-fill-border-color, var(--global-colors-primary500))",
						"product-count-button-border-hover": "1px solid var(--button-fill-border-color-hover, var(--global-colors-primary700))",
						"product-count-button-border-focus": "1px solid var(--button-fill-border-color-focus, transparent)"
					}
				}
			],
			"outline": [
				{
					"variable": {
						"product-count-button-background-color": "transparent",
						"product-count-button-color": "var(--button-outline-color, var(--global-colors-primary500))",
						"product-count-button-color-hover": "var(--button-outline-color-hover, var(--global-colors-primary700))",
						"product-count-button-border": "1px solid var(--button-outline-border-color, var(--global-colors-primary500))",
						"product-count-button-border-hover": "1px solid var(--button-outline-border-color-hover, var(--global-colors-primary700))",
						"product-count-button-border-focus": "1px solid var(--button-outline-border-color-focus, transparent)"
					}
				}
			],
			"ghost": [
				{
					"variable": {
						"product-count-button-background-color": "transparent",
						"product-count-button-color": "var(--button-ghost-color, var(--global-colors-primary500))",
						"product-count-button-color-hover": "var(--button-ghost-color-hover, var(--global-colors-primary700))",
						"product-count-button-border": "1px solid transparent"
					}
				}
			]
		}
	}
}
