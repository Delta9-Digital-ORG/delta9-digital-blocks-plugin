{
	"$schema": "https://raw.githubusercontent.com/infinum/eightshift-frontend-libs/develop/schemas/block.json",
	"blockName": "category-label",
	"title": "Category Label",
	"description": "Displays nested product category names with flexible ordering. Works on taxonomy archives and in the product loop.",
	"category": "eightshift",
	"icon": {
		"src": "es-button"
	},
	"keywords": [
		"category",
		"label",
		"taxonomy",
		"term"
	],
	"attributes": {
		"categoryLabelServerSideRender": {
			"type": "boolean",
			"default": false
		},
		"categoryLabelSource": {
			"type": "object",
			"default": {
				"label": "Archive (Current Term)",
				"value": "archive",
				"restName": "archive"
			}
		},
		"categoryLabelParentSlug": {
			"type": "object",
			"default": {
				"label": "None",
				"value": "",
				"restName": ""
			}
		},
		"categoryLabelFormat": {
			"type": "object",
			"default": {
				"label": "Child Parent",
				"value": "child-parent",
				"restName": "child-parent"
			}
		},
		"categoryLabelSeparator": {
			"type": "string",
			"default": " "
		},
		"categoryLabelTransform": {
			"type": "object",
			"default": {
				"label": "Uppercase",
				"value": "uppercase",
				"restName": "uppercase"
			}
		}
	},
	"allowed": {
		"sources": [
			{
				"label": "Archive (Current Term)",
				"value": "archive",
				"restName": "archive"
			},
			{
				"label": "Product Loop",
				"value": "product",
				"restName": "product"
			}
		],
		"parentSlugs": [
			{
				"label": "None",
				"value": "",
				"restName": ""
			},
			{
				"label": "Active Ingredients",
				"value": "active-ingredients",
				"restName": "active-ingredients"
			},
			{
				"label": "Nutrition Facts",
				"value": "nutrition-facts",
				"restName": "nutrition-facts"
			},
			{
				"label": "Ingredients",
				"value": "ingredients",
				"restName": "ingredients"
			},
			{
				"label": "Mood",
				"value": "mood",
				"restName": "mood"
			},
			{
				"label": "Product Type",
				"value": "product-type",
				"restName": "product-type"
			},
			{
				"label": "Cana Facts",
				"value": "cana-facts",
				"restName": "cana-facts"
			}
		],
		"formats": [
			{
				"label": "Child Parent",
				"value": "child-parent",
				"restName": "child-parent"
			},
			{
				"label": "Parent Child",
				"value": "parent-child",
				"restName": "parent-child"
			},
			{
				"label": "Parent Only",
				"value": "parent-only",
				"restName": "parent-only"
			},
			{
				"label": "Child Only",
				"value": "child-only",
				"restName": "child-only"
			}
		],
		"transforms": [
			{
				"label": "Uppercase",
				"value": "uppercase",
				"restName": "uppercase"
			},
			{
				"label": "Lowercase",
				"value": "lowercase",
				"restName": "lowercase"
			},
			{
				"label": "Capitalize",
				"value": "capitalize",
				"restName": "capitalize"
			},
			{
				"label": "None",
				"value": "none",
				"restName": "none"
			}
		]
	},
	"hasInnerBlocks": true,
	"useWrapper": false
}
