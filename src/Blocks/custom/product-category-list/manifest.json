{
	"$schema": "https://raw.githubusercontent.com/infinum/eightshift-frontend-libs/develop/schemas/block.json",
	"blockName": "product-category-list",
	"title": "Product Category List (Custom)",
	"description" : "WooCommerce product category list block.",
	"category": "eightshift",
	"icon": {
		"src": "es-button"
	},
	"keywords": [
		"product",
		"category"
	],
	"attributes": {
		"productCategoryListServerSideRender": {
			"type": "boolean",
			"default": false
		},
		"productCategoryListSlug": {
			"type": "object",
			"default": {
				"label": "Nutrition Facts",
				"value": "nutrition-facts",
				"restName": "nutrition-facts"
			}
		},
		"productCategoryListFormat": {
			"type": "object"
		}
	},
	"allowed": {
		"categories": [
			{
				"label": "Nutrition Facts",
				"value": "nutrition-facts",
				"restName": "nutrition-facts"
			},
			{
				"label": "Ingredients",
				"value": "ingredients",
				"restName": "ingredients"
			},
			{
				"label": "Mood",
				"value": "mood",
				"restName": "mood"
			},
			{
				"label": "Active Ingredients",
				"value": "active-ingredients",
				"restName": "active-ingredients"
			},
			{
				"label": "Active Ingredient Label",
				"value": "active-ingredient-label",
				"restName": "active-ingredient-label"
			},
			{
				"label": "Product Type",
				"value": "product-type",
				"restName": "product-type"
			},
			{
				"label": "Cana Facts",
				"value": "cana-facts",
				"restName": "cana-facts"
			}
		],
		"displayFormat": [
			{
				"label": "List",
				"value": "List",
				"restName": "List"
			},
			{
				"label": "Nutrition Facts",
				"value": "Nutrition Facts",
				"restName": "Nutrition Facts"
			}
		]
	},
	"useWrapper": false
}
