{
	"$schema": "https://raw.githubusercontent.com/infinum/eightshift-frontend-libs/develop/schemas/block.json",
	"blockName": "tax-query-menu-item",
	"blockJsClass": "js-block-tax-query-menu-item",
	"blockClass": "block-tax-query-menu-item",
	"title": "Tax Query Menu Item",
	"description": "Tax Query Menu Item Description",
	"category": "eightshift",
	"icon": {
		"src": "<svg width='20' height='20' xmlns='http://www.w3.org/2000/svg'><g fill='none' fill-rule='evenodd'><path fill='none' d='M0 0h20v20H0z'/><path d='M14.5 1A1.5 1.5 0 0116 2.5v10.304l-.53-.077L14 9.75l-1.47 2.977-3.285.478 2.377 2.318-.082.477H2.5A1.5 1.5 0 011 14.5v-12A1.5 1.5 0 012.5 1h12z' stroke='currentColor' stroke-width='1.5' stroke-linejoin='round'/><path stroke='currentColor' stroke-width='1.5' fill-opacity='.12' fill='currentColor' stroke-linejoin='round' d='M14 17.25l-2.939 1.545.561-3.272-2.377-2.318 3.286-.478L14 9.75l1.469 2.977 3.286.478-2.377 2.318.561 3.272zM4 4h3v3H4zM4 10h3v3H4zM10 4h3v3h-3z'/></g></svg>"
	},
	"keywords": [
		"Tax Query Menu Keyword"
	],
	"example": {
		"attributes": {
			"taxQueryMenuItem": {
				"taxonomy": "category",
				"terms": []
			},
			"taxQueryMenuItemServerSideRender": false
		},
		"innerBlocks": [
			{
				"name": "eightshift-boilerplate/button"
			}
		]
	},
	"components": {
		"button": "button"
	},
	"hasInnerBlocks": true,
	"attributes": {
		"taxQueryMenuItemContent": {
			"type": "string"
		},
		"taxQueryMenuItemServerSideRender": {
			"type": "boolean",
			"default": false
		},
		"taxQueryMenuItemPickTaxonomyManually": {
			"type": "boolean"
		},
		"taxQueryMenuItemPickTaxonomyAll": {
			"type": "boolean"
		},
		"taxQueryMenuItemPickTaxonomyOther": {
			"type": "boolean"
		},
		"taxQueryMenuItemShowCount": {
			"type": "boolean"
		},
		"taxQueryMenuItemTaxonomy": {
			"type": "object",
			"default": {
				"label": "Category",
				"value": "category",
				"restName": "categories"
			}
		},
		"taxQueryMenuItemManualTerms": {
			"type": "array"
		},
		"taxQueryMenuItemButtonAlign": {
			"type": "string",
			"default": "left"
		}
	},
	"options": {
		"taxQueryMenuItemButtonAlign": [
			{
				"label": "Left",
				"value": "left",
				"icon": "horizontalAlignLeft"
			},
			{
				"label": "Center",
				"value": "center",
				"icon": "horizontalAlignCenter"
			},
			{
				"label": "Right",
				"value": "right",
				"icon": "horizontalAlignRight"
			},
			{
				"label": "Mobile",
				"value": "mobile",
				"icon": "horizontalAlignCenter"
			}
		]
	},
	"allowed": {
		"taxonomies": [
			{
				"label": "Category",
				"value": "category",
				"restName": "categories"
			},
			{
				"label": "Industry",
				"value": "industry",
				"restName": "industry"
			},
			{
				"label": "Persona",
				"value": "persona",
				"restName": "persona"
			}
		]
	},
	"configPresets": [
		{
			"name": "View All",
			"icon": "width",
			"attributes": {
				"taxQueryMenuItemPickTaxonomyManually": false,
				"taxQueryMenuItemPickTaxonomyOther": false,
				"taxQueryMenuItemPickTaxonomyAll": true
			}
		},
		{
			"name": "Other",
			"icon": "wrapperSimple",
			"attributes": {
				"taxQueryMenuItemPickTaxonomyAll": false,
				"taxQueryMenuItemPickTaxonomyManually": true,
				"taxQueryMenuItemPickTaxonomyOther": true
			}
		}
	]
}