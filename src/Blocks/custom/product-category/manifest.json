{
	"$schema": "https://raw.githubusercontent.com/infinum/eightshift-frontend-libs/develop/schemas/block.json",
	"blockName": "product-category",
	"title": "Product Category",
	"description" : "WooCommerce product category block.",
	"category": "eightshift",
	"icon": {
		"src": "es-button"
	},
	"keywords": [
		"product",
		"category"
	],
	"attributes": {
		"productCategoryServerSideRender": {
			"type": "boolean",
			"default": false
		},
		"productCategorySlug": {
			"type": "object",
			"default": {
				"label": "Nutrition Facts",
				"value": "Nutrition Facts",
				"restName": "Nutrition Facts"
			}
		},
		"productCategoryBorder": {
			"type": "boolean",
			"default": false
		},
		"productCategoryBorderThick": {
			"type": "boolean",
			"default": false
		},
		"productCategoryDisplayGrandchildren": {
			"type": "boolean",
			"default": false
		},
		"productCategoryFormat": {
			"type": "object",
			"default": {
				"label": "None",
				"value": "None",
				"restName": "None"
			}
		}
	},
	"allowed": {
		"categories": [
			{
				"label": "Nutrition Facts",
				"value": "nutrition-facts",
				"restName": "nutrition-facts"
			},
			{
				"label": "Ingredients",
				"value": "ingredients",
				"restName": "ingredients"
			},
			{
				"label": "Mood",
				"value": "mood",
				"restName": "mood"
			},
			{
				"label": "Active Ingredients",
				"value": "active-ingredients",
				"restName": "active-ingredients"
			},
			{
				"label": "Active Ingredient Label",
				"value": "active-ingredient-label",
				"restName": "active-ingredient-label"
			},
			{
				"label": "Product Type",
				"value": "product-type",
				"restName": "product-type"
			},
			{
				"label": "Cana Facts",
				"value": "cana-facts",
				"restName": "cana-facts"
			}
		],
		"displayFormat": [
			{
				"label": "None",
				"value": "None",
				"restName": "None"
			},
			{
				"label": "Stacked",
				"value": "Stacked",
				"restName": "Stacked"
			},
			{
				"label": "Reverse Order",
				"value": "Reverse Order",
				"restName": "Reverse Order"
			}
		]
	},
	"useWrapper": false
}
